# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# --- Public (safe to expose to the browser) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Selvra

# --- Server-only (never prefix with NEXT_PUBLIC_) ---

# Selvra-protokollets HTTP-fasad (live på Railway)
# URL till protokollets HTTP-API
SELVRA_PROTOCOL_URL=https://selvra-production.up.railway.app

# JWT-secret för signering av tokens mot protokollet.
# Genereras via ~/selvra/scripts/seed_vertical_tenant.py.
# Måste matchas mot Selvras MCP_JWT_SECRETS-array.
SELVRA_PROTOCOL_JWT_SECRET=

# Tenant + subject för denna app-instans (Carl-dogfood).
# Tenant_id seedat 2026-05-10. Subject_id är UUID5(NAMESPACE, tenant:external_id).
SELVRA_TENANT_ID=
SELVRA_SOURCE_ID=selvra-app
SELVRA_SUBJECT_EXTERNAL_ID=carl
SELVRA_SUBJECT_ID=

# Stable sub-UUID för selvra-app:s JWT-claims.
# Måste matchas mot beviljad ConsentGrant.source_ai_id i Selvra.
SELVRA_APP_SUB_UUID=

# --- Framtida (Steg C+) ---

# Magic-link mail (Resend eller liknande)
# RESEND_API_KEY=
# MAIL_FROM=brev@selvra.app

# Terra API (källa-aggregator för wearables)
# TERRA_API_KEY=
# TERRA_DEV_ID=
# TERRA_WEBHOOK_SECRET=
