# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# --- Public (safe to expose to the browser) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Selvra

# --- Auth.js v5 (Magic-link auth) ---

# Postgres connection-string för selvra-app:s egen DB (Railway).
# Auto-injectas av Railway när Postgres-tjänsten är linkad.
DATABASE_URL=

# Resend API-nyckel (https://resend.com). Magic-link mail.
RESEND_API_KEY=

# Mail-avsändare. Använd onboarding@resend.dev tills DKIM/SPF för
# selvra.ai är konfat. Sen byt till noreply@selvra.ai.
MAIL_FROM=onboarding@resend.dev

# Auth.js secret för session-signering. Generera med:
#   openssl rand -base64 32
AUTH_SECRET=

# --- Selvra-protokoll (HTTP-fasad live på Railway) ---

SELVRA_PROTOCOL_URL=https://selvra-production.up.railway.app

# JWT-secret för signering av tokens mot protokollet.
# Genereras via ~/selvra/scripts/seed_vertical_tenant.py.
SELVRA_PROTOCOL_JWT_SECRET=

# selvra-app:s tenant + Carl-subject (dogfood-v0, single-user).
# När magic-link onboarding körs för riktiga users tas dessa från users-tabellen.
SELVRA_TENANT_ID=
SELVRA_SOURCE_ID=selvra-app
SELVRA_SUBJECT_EXTERNAL_ID=carl
SELVRA_SUBJECT_ID=

# Stable sub-UUID för selvra-app:s JWT-claims (ConsentGrant.source_ai_id).
SELVRA_APP_SUB_UUID=

# --- Strava OAuth (källa: aktiviteter) ---
# Skapa OAuth-app på https://www.strava.com/settings/api
# Authorization Callback Domain: localhost (för dev) eller selvra.ai (för prod)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Tokens från OAuth-callback (v0 stub-storage; ersätts av DB när Magic-link wired)
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_EXPIRES_AT=
STRAVA_SCOPE=
STRAVA_ATHLETE_ID=
# Webhook verify-token (för Strava-webhook-subscription, kräver publik URL)
STRAVA_WEBHOOK_VERIFY_TOKEN=

# --- Google OAuth (källor: Calendar + Gmail-metadata) ---
# Skapa OAuth-app i Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# - APIs enabled: Google Calendar API + Gmail API
# - Scopes: calendar.readonly + gmail.metadata + openid + email
# - Authorized redirect URI: http://localhost:3000/api/oauth/google/callback (dev)
#                            https://selvra.ai/api/oauth/google/callback (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Tokens från OAuth-callback (v0 stub-storage; ersätts av DB post-AB)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_EXPIRES_AT=
GOOGLE_SCOPE=
GOOGLE_USER_ID=

# --- Framtida ---

# Spotify OAuth — v1.1 (soft-include)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
