# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# --- Public (safe to expose to the browser) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Selvra

# --- Server-only (never prefix with NEXT_PUBLIC_) ---

# Selvra-protokollets HTTP-fasad (live på Railway)
# SELVRA_PROTOCOL_URL=https://selvra-production.up.railway.app
# SELVRA_PROTOCOL_API_KEY=

# Magic-link mail (Resend eller liknande)
# RESEND_API_KEY=
# MAIL_FROM=brev@selvra.app

# Terra API (källa-aggregator för wearables)
# TERRA_API_KEY=
# TERRA_DEV_ID=
# TERRA_WEBHOOK_SECRET=

# Session signing
# SESSION_SECRET=
